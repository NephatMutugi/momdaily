// MomDaily schema — Phase 4.
// Postgres (Vercel Postgres, Neon-backed).
//
// Phase 4 adds: EmailPreference (per-user opt-ins + send hour) and
// EmailSendLog (idempotency: one row per user/kind/day prevents the cron
// from double-sending if it retries or runs concurrently).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Enums ---

enum Goal {
  sleep
  feeding
  milestones
  self_care
}

enum FeedingStage {
  breast
  formula
  mixed
  solids
  family_foods
}

enum TipCategory {
  nutrition
  sleep
  milestones
  self_care
  safety
}

enum EmailKind {
  morning
  evening
  weekly_recap
}

// --- NextAuth required tables ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- Domain models ---

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  passwordHash  String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile / preferences
  timezone  String  @default("UTC")
  locale    String  @default("en")
  topGoal   Goal?
  onboarded Boolean @default(false)

  accounts         Account[]
  sessions         Session[]
  children         Child[]
  tipsShown        TipShown[]
  tipFeedback      TipFeedback[]
  habits           Habit[]
  habitLogs        HabitLog[]
  emailPreference  EmailPreference?
  emailSendLogs    EmailSendLog[]
}

model Child {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String?
  birthdate    DateTime
  feedingStage FeedingStage
  gender       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId])
}

// --- Tip catalog ---

model Tip {
  id              String      @id @default(cuid())
  slug            String      @unique
  title           String
  body            String
  category        TipCategory
  ageMinMonths    Int
  ageMaxMonths    Int
  goalsHit        Goal[]
  helpfulCount    Int         @default(0)
  notHelpfulCount Int         @default(0)
  sources         String[]
  publishedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  shownTo   TipShown[]
  feedbacks TipFeedback[]

  @@index([publishedAt])
  @@index([category])
  @@index([ageMinMonths, ageMaxMonths])
}

model TipShown {
  id      String   @id @default(cuid())
  userId  String
  tipId   String
  shownAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tip  Tip  @relation(fields: [tipId], references: [id], onDelete: Cascade)

  @@unique([userId, tipId])
  @@index([userId, shownAt])
}

model TipFeedback {
  id        String   @id @default(cuid())
  userId    String
  tipId     String
  helpful   Boolean
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tip  Tip  @relation(fields: [tipId], references: [id], onDelete: Cascade)

  @@unique([userId, tipId])
  @@index([tipId])
}

// --- Habits (Phase 3) ---

model Habit {
  id        String   @id @default(cuid())
  userId    String
  // Stable identifier independent of label. Used for default-habit seeding
  // and to keep historical logs intact when the user renames a habit.
  key       String
  label     String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@unique([userId, key])
  @@index([userId, active])
}

model HabitLog {
  id      String @id @default(cuid())
  userId  String
  habitId String
  // Stored as a date-only column. The API computes "today" in the user's
  // timezone and converts to a UTC-midnight Date before write.
  loggedDate DateTime @db.Date
  value      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  // One row per habit per day. Re-toggling updates `value` instead of stacking.
  @@unique([userId, habitId, loggedDate])
  @@index([userId, loggedDate])
}

// --- Email (Phase 4) ---

// One row per user. Created lazily on first need (onboarding completion or
// the first cron pass). Send time is stored in the user's local clock — the
// cron resolves it against User.timezone at send time.
model EmailPreference {
  id              String  @id @default(cuid())
  userId          String  @unique
  morningEnabled  Boolean @default(true)
  eveningEnabled  Boolean @default(false)
  weeklyEnabled   Boolean @default(true)
  // Hour 0–23 in the user's local timezone. Default 7am.
  sendHourLocal   Int     @default(7)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Idempotency guard for the cron. Before sending, the cron upserts a row
// here keyed by (userId, kind, sentDate). If the row already existed, the
// cron skips the send — so a retry, concurrent invocation, or accidental
// re-trigger can't double-mail anyone.
model EmailSendLog {
  id        String    @id @default(cuid())
  userId    String
  kind      EmailKind
  // The user's local date the email was sent for, normalized to UTC midnight.
  sentDate  DateTime  @db.Date
  // Resend's message id, captured for debugging deliverability issues.
  providerMessageId String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, sentDate])
  @@index([userId, kind])
}
