# Vercel Postgres (Neon-backed) — pooled URL for runtime
DATABASE_URL=""
# Direct (unpooled) URL for migrations / prisma db push
DIRECT_URL=""

# Phase 1 adds NextAuth — fill these when you wire it up.
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Optional — enables "Continue with Google" on /signup and /login.
# See DEPLOY.md for the Google Cloud Console setup. The Google button is
# automatically hidden if these aren't set, so the credentials flow keeps
# working without them.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Phase 4 adds Resend (transactional email).
RESEND_API_KEY=""
EMAIL_FROM="MomDaily <hello@yourdomain.com>"
# Shared secret for the morning-email cron endpoint. Vercel Cron auto-injects
# its own header in production, but you still want this set for local testing
# and for any external scheduler (GitHub Actions, etc.).
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# Optional override. Falls back to NEXTAUTH_URL otherwise. Useful when
# running cron against a preview deploy from your laptop.
APP_ORIGIN=""

# Phase 8 adds Claude. Without this, the AI coach is hidden.
ANTHROPIC_API_KEY=""
