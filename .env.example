# Vercel Postgres (Neon-backed) — pooled URL for runtime
DATABASE_URL=""
# Direct (unpooled) URL for migrations / prisma db push
DIRECT_URL=""

# NextAuth (Phase 1)
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Optional — enables "Continue with Google" on /signup and /login.
# See DEPLOY.md for the Google Cloud Console setup. The Google button is
# automatically hidden if these aren't set, so the credentials flow keeps
# working without them.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend — required only for password reset emails. Without these, the
# /forgot-password endpoint still returns 200 (privacy) but no email is sent.
# Get a key at resend.com; EMAIL_FROM must be on a verified sending domain
# (see DEPLOY.md). For dev you can use "MomDaily <onboarding@resend.dev>".
RESEND_API_KEY=""
EMAIL_FROM="MomDaily <onboarding@resend.dev>"

# Phase 8 adds Claude. Without this, the AI coach is hidden.
ANTHROPIC_API_KEY=""
